# App branding
FOLLOWUP_APP_NAME=Smart Follow-up Assistant
FOLLOWUP_APP_SUBTITLE=Clinical Research Follow-up Management System
FOLLOWUP_APP_COPYRIGHT=© 2026 Smart Follow-up Assistant contributors
FOLLOWUP_APP_NOTICE=This software is intended for authorized clinical research follow-up workflows.
FOLLOWUP_SUPPORT_EMAIL=

# Django
FOLLOWUP_DEBUG=true
DJANGO_SECRET_KEY=replace-with-a-random-secret-key
FOLLOWUP_DB_PATH=
FOLLOWUP_ALLOWED_HOSTS=127.0.0.1,localhost
FOLLOWUP_CSRF_TRUSTED_ORIGINS=

# AI
AI_PROVIDER=aliyun
AI_API_KEY=replace-with-your-api-key
AI_MODEL=qwen-plus
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
AI_USE_ENV_PROXY=false
